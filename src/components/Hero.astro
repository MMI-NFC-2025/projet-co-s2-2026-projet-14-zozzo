<section class="relative overflow-hidden bg-[#f2f2f2] pt-16 sm:pt-20 lg:pt-24">
  <!-- Version mobile : têtes en absolute -->
  <img
    src="/images/landing/head-zozzo-right.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute right-[-10px] top-[34px] z-30 w-[120px] sm:w-[150px] lg:hidden"
  />

  <img
    src="/images/landing/head-zozzo-left.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute left-[-18px] top-[260px] z-30 w-[120px] sm:top-[300px] sm:w-[150px] lg:hidden"
  />

  <div class="container-zozzo relative z-20">
    <div class="relative min-h-[520px] sm:min-h-[620px] lg:min-h-[760px]">
      <!-- Structure principale en colonnes sur desktop -->
      <div
        class="grid items-start lg:grid-cols-[220px_minmax(0,1fr)_220px] lg:gap-6"
      >
        <!-- Tête gauche desktop -->
        <div class="hidden lg:flex lg:justify-start lg:pt-[250px]">
          <img
            src="/images/landing/head-zozzo-left.svg"
            alt=""
            aria-hidden="true"
            class="w-[220px]"
          />
        </div>

        <!-- Bloc texte -->
        <div
          class="relative max-w-[640px] pt-14 text-left sm:pt-16 lg:max-w-[920px] lg:pt-[68px]"
        >
          <h1
            class="font-['Biryani'] text-[2.35rem] leading-[0.95] font-normal text-black sm:text-[3.15rem] lg:text-[4.6rem]"
          >
            Apprendre la langue des<br />
            signes enfant
          </h1>

          <p
            class="mt-4 max-w-[580px] font-['Biryani'] text-[1rem] leading-[1.05] font-normal text-black sm:text-[1.22rem] lg:text-[1.9rem]"
          >
            Des histoires qui valent plus que des mots.
          </p>

          <div
            class="mt-3 max-w-[590px] text-left font-['Montserrat'] text-[0.95rem] leading-[1.38] text-black/85 sm:text-[1rem] lg:text-[1.08rem] lg:leading-[1.34]"
          >
            <p>Votre enfant passe du temps sur les écrans.</p>
            <p>Et si ce temps devenait utile ?</p>
            <p>
              Avec Zozzo, il apprend la langue des signes facilement, développe
              son empathie et découvre une nouvelle façon de communiquer.
            </p>
          </div>

          <a
            id="telecharger"
            href="#"
            class="mt-7 inline-flex min-h-[58px] items-center justify-center rounded-full bg-[#ece339] px-8 text-[1.05rem] font-semibold text-[#224ed1] transition hover:scale-105 sm:min-h-[68px] sm:px-12 sm:text-[1.2rem] lg:mt-8 lg:min-h-[78px] lg:px-16 lg:text-[1.45rem]"
          >
            Télécharger Zozzo
          </a>
        </div>

        <!-- Tête droite desktop -->
        <div class="hidden lg:flex lg:justify-end lg:pt-[18px]">
          <img
            src="/images/landing/head-zozzo-right.svg"
            alt=""
            aria-hidden="true"
            class="w-[220px]"
          />
        </div>
      </div>

      <!-- Étoiles bas gauche -->
      <img
        src="/images/landing/star-1.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute left-[18px] top-[565px] z-20 hidden w-[26px] sm:block lg:left-[18px] lg:top-[646px] lg:w-[40px]"
      />
      <img
        src="/images/landing/star-2.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute left-[54px] top-[612px] z-20 hidden w-[22px] sm:block lg:left-[56px] lg:top-[704px] lg:w-[32px]"
      />
      <img
        src="/images/landing/star-1.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute left-[14px] top-[650px] z-20 hidden w-[20px] sm:block lg:left-[10px] lg:top-[758px] lg:w-[28px]"
      />
    </div>
  </div>

  <!-- Grand décor principal -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-[-12px] z-0 flex justify-center sm:bottom-[-20px] lg:bottom-[-28px]"
  >
    <img
      src="/images/landing/zozzo-hero-main.png"
      alt=""
      aria-hidden="true"
      class="w-[980px] max-w-none sm:w-[1250px] lg:w-[1750px]"
    />
  </div>
</section>
<!-- Nuages -->
<img
  src="/images/landing/cloud-1.svg"
  alt=""
  aria-hidden="true"
  class="pointer-events-none absolute left-[24%] top-[250px] z-10 hidden w-[58px] opacity-95 sm:block md:w-[70px] lg:left-[22%] lg:top-[255px] lg:w-[96px]"
/>

<img
  src="/images/landing/cloud-2.svg"
  alt=""
  aria-hidden="true"
  class="pointer-events-none absolute right-[24%] top-[244px] z-10 hidden w-[58px] opacity-95 sm:block md:w-[70px] lg:right-[23%] lg:top-[248px] lg:w-[96px]"
/>
