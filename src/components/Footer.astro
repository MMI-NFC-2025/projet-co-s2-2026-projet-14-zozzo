---
const footerNavigation = [
  { href: "/fonctionnalites", label: "Fonctionnalités" },
  { href: "/apropos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];

const legalLinks = [
  { href: "/conditions-generales", label: "Conditions Générales" },
  { href: "/mentions-legales", label: "Mentions légales" },
  { href: "/donnees-personnelles", label: "Données personnelles" },
  { href: "/cookies", label: "Gérer mes cookies" },
  { href: "/cookies", label: "Politique cookies" },
];
---

<footer class="mt-auto">
  <div class="bg-zozzo-jaune">
    <div class="mx-auto max-w-7xl px-10 py-8 md:px-10 md:py-8">
      <nav
        class="flex flex-col items-start gap-8 text-[26px] font-normal leading-none text-zozzo-blue md:gap-10"
        style="font-family: var(--font-subtitle);"
        aria-label="Navigation du pied de page"
      >
        {
          footerNavigation.map((item) => (
            <a href={item.href} class="transition-opacity hover:opacity-70">
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mx-auto max-w-7xl px-10 md:px-10">
      <div
        class="h-px w-full"
        style="background-color: var(--color-zozzo-bleu-fonce);"
      >
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-10 py-6 md:px-10 md:py-5">
      <div
        class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3 text-[12px] font-normal text-zozzo-blue"
        style="font-family: var(--font-sans);"
      >
        {
          legalLinks.map((item) => (
            <a href={item.href} class="transition-opacity hover:opacity-70">
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
