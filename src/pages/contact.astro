---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="ZOZZO | Contact"
  description="Contactez l'équipe ZOZZO pour échanger autour du projet et de ses usages pédagogiques."
>
  <section
    class="relative overflow-hidden bg-[#efefef] px-6 py-12 sm:px-10 md:px-14 lg:min-h-[980px] lg:px-20 lg:py-16"
  >
    <!-- forme jaune décorative -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <svg
        viewBox="0 0 900 900"
        class="absolute right-[-260px] top-[-40px] h-[980px] w-[980px] opacity-100 md:right-[-180px] md:top-[-10px] md:h-[1050px] md:w-[1050px] lg:right-[-120px] lg:top-[-30px] xl:right-[-40px]"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M690 20
           C540 110, 440 180, 500 260
           C560 340, 700 250, 760 340
           C820 430, 730 610, 610 720
           C490 830, 330 790, 360 640
           C390 500, 560 470, 650 580
           C740 690, 760 810, 740 920"
          stroke="#E9DF33"
          stroke-width="92"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>

    <div class="relative z-10 max-w-[760px]">
      <h1
        class="mb-10 text-[56px] leading-none text-black sm:text-[64px] md:text-[72px]"
      >
        Contact
      </h1>

      <form class="w-full max-w-[620px] space-y-7">
        <div>
          <label for="nom" class="mb-2 block text-[18px] text-black">Nom</label>
          <input
            id="nom"
            name="nom"
            type="text"
            placeholder="Dubois"
            class="h-[42px] w-full rounded-[4px] border-0 bg-[#d9d9d9] px-4 text-[18px] text-black placeholder:text-[#b5b5b5] focus:outline-none"
          />
        </div>

        <div>
          <label for="prenom" class="mb-2 block text-[18px] text-black"
            >Prénom</label
          >
          <input
            id="prenom"
            name="prenom"
            type="text"
            placeholder="Anne"
            class="h-[42px] w-full rounded-[4px] border-0 bg-[#d9d9d9] px-4 text-[18px] text-black placeholder:text-[#b5b5b5] focus:outline-none"
          />
        </div>

        <div>
          <label for="statut" class="mb-2 block text-[18px] text-black"
            >Statut</label
          >
          <input
            id="statut"
            name="statut"
            type="text"
            placeholder="Enseignant(e)"
            class="h-[42px] w-full rounded-[4px] border-0 bg-[#d9d9d9] px-4 text-[18px] text-black placeholder:text-[#b5b5b5] focus:outline-none"
          />
        </div>

        <div class="relative">
          <div class="mb-2 flex items-center justify-between">
            <label for="message" class="block text-[18px] text-black"
              >Message</label
            >

            <svg
              class="h-5 w-5 text-[#b5b5b5]"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M4 7L10 13L16 7"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>

          <textarea
            id="message"
            name="message"
            rows="8"
            placeholder="..."
            class="min-h-[240px] w-full resize-none rounded-[4px] border-0 bg-[#d9d9d9] px-4 py-3 text-[18px] text-black placeholder:text-[#b5b5b5] focus:outline-none sm:min-h-[270px]"
          ></textarea>
        </div>

        <div class="pt-4 sm:pt-6">
          <button
            type="submit"
            class="mx-auto block w-full max-w-[290px] rounded-[24px] bg-[#2f56d6] px-8 py-5 text-center text-[28px] text-white transition hover:scale-[1.02]"
          >
            Envoyer
          </button>
        </div>
      </form>
    </div>
  </section>
</Layout>
