---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="ZOZZO | Contact"
  description="Contactez l'équipe ZOZZO pour échanger autour du projet et de ses usages pédagogiques."
>
  <section
    class="relative overflow-hidden bg-[#efefef] px-6 py-10 sm:px-10 sm:py-12 md:px-14 lg:min-h-245 lg:px-20 lg:py-16"
  >
    <!-- forme jaune décorative -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <svg
        viewBox="0 0 900 900"
        class="absolute -right-88 -top-12 h-190 w-190 opacity-100 sm:-right-82 sm:h-215 sm:w-215 md:-right-45 md:-top-2.5 md:h-262.5 md:w-262.5 lg:-right-30 lg:-top-7.5 xl:-right-10"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M690 20
           C540 110, 440 180, 500 260
           C560 340, 700 250, 760 340
           C820 430, 730 610, 610 720
           C490 830, 330 790, 360 640
           C390 500, 560 470, 650 580
           C740 690, 760 810, 740 920"
          stroke="#E9DF33"
          stroke-width="92"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>

    <div class="relative z-10 max-w-170 lg:max-w-190">
      <h1
        class="mb-8 text-4xl leading-none text-black sm:mb-10 sm:text-5xl md:text-6xl lg:text-[72px]"
      >
        Contact
      </h1>

      <form class="w-full max-w-150 space-y-6 sm:space-y-7">
        <div>
          <label for="nom" class="mb-2 block text-base text-black sm:text-lg"
            >Nom</label
          >
          <input
            id="nom"
            name="nom"
            type="text"
            placeholder="Dubois"
            class="h-11 w-full rounded-sm border-0 bg-[#d9d9d9] px-4 text-base text-black placeholder:text-[#b5b5b5] focus:outline-none sm:h-12 sm:text-lg"
          />
        </div>

        <div>
          <label for="prenom" class="mb-2 block text-base text-black sm:text-lg"
            >Prénom</label
          >
          <input
            id="prenom"
            name="prenom"
            type="text"
            placeholder="Anne"
            class="h-11 w-full rounded-sm border-0 bg-[#d9d9d9] px-4 text-base text-black placeholder:text-[#b5b5b5] focus:outline-none sm:h-12 sm:text-lg"
          />
        </div>

        <div>
          <label for="statut" class="mb-2 block text-base text-black sm:text-lg"
            >Statut</label
          >
          <input
            id="statut"
            name="statut"
            type="text"
            placeholder="Enseignant(e)"
            class="h-11 w-full rounded-sm border-0 bg-[#d9d9d9] px-4 text-base text-black placeholder:text-[#b5b5b5] focus:outline-none sm:h-12 sm:text-lg"
          />
        </div>

        <div class="relative">
          <div class="mb-2 flex items-center justify-between">
            <label for="message" class="block text-base text-black sm:text-lg"
              >Message</label
            >

            <svg
              class="h-5 w-5 text-[#b5b5b5]"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M4 7L10 13L16 7"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>

          <textarea
            id="message"
            name="message"
            rows="8"
            placeholder="..."
            class="min-h-44 w-full resize-none rounded-sm border-0 bg-[#d9d9d9] px-4 py-3 text-base text-black placeholder:text-[#b5b5b5] focus:outline-none sm:min-h-56 sm:text-lg md:min-h-67.5"
          ></textarea>
        </div>

        <div class="pt-4 sm:pt-6">
          <button
            type="submit"
            class="mx-auto block w-full max-w-64 rounded-3xl bg-zozzo-bleu-fonce px-8 py-4 text-center text-xl text-white transition hover:scale-[1.02] sm:max-w-72.5 sm:py-5 sm:text-2xl"
          >
            Envoyer
          </button>
        </div>
      </form>
    </div>
  </section>
</Layout>
